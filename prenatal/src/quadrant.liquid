<style>
  .prenatal-q {
    height: 100%;
  }

  .prenatal-q .panel {
    height: 100%;
    padding: 16px;
    box-sizing: border-box;
    border: 2px solid var(--black);
    border-radius: 18px;
  }

  .prenatal-q .hero {
    height: 100%;
    min-width: 0;
    display: flex;
    gap: 16px;
    align-items: stretch;
    justify-content: flex-start;
    overflow: hidden;
  }

  .prenatal-q .copy {
    flex: 1 1 0;
    min-width: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    font-family: "Inter Variable", Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .prenatal-q .copy-top,
  .prenatal-q .copy-bottom,
  .prenatal-q .size-line {
    width: 100%;
    min-width: 0;
  }

  .prenatal-q .copy-top,
  .prenatal-q .copy-bottom {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 4px;
  }

  .prenatal-q .copy-text {
    font-size: 19px;
    line-height: 1.08;
    font-weight: 600;
    letter-spacing: -0.01em;
    white-space: normal;
    text-align: left;
  }

  .prenatal-q .divider {
    width: 100%;
    height: 0;
    margin: 10px 0;
    border-top: 1px solid var(--gray-60);
  }

  .prenatal-q .size-line {
    text-align: justify;
    text-align-last: left;
  }

  .prenatal-q .size-line strong {
    font-weight: 700;
  }

  .prenatal-q .image-column {
    flex: 0 0 auto;
    height: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: stretch;
  }

  .prenatal-q .image-frame {
    height: 100%;
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--white);
    display: flex;
    align-items: stretch;
  }

  .prenatal-q .fruit-image {
    height: 100%;
    width: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
  }
</style>

<div class="layout layout--col prenatal-q">
  <div class="panel">
    <div class="hero">
      <div class="copy">
        <div class="copy-top">
          <div class="copy-text">{{ gestation_weeks }} weeks</div>
          <div class="copy-text">{{ gestation_days }} days old</div>

          <div class="divider"></div>

          <div class="copy-text size-line" data-clamp="3">
            {% if fruit_name == "Still Forming" %}
              Your baby is <strong>{{ fruit_name | downcase }}</strong>
            {% else %}
              Your baby is the size of <strong>{{ fruit_size_phrase }}</strong>
            {% endif %}
          </div>

          <div class="divider"></div>
        </div>

        <div class="copy-bottom">
          <div class="copy-text">{{ due_weeks_remaining }} weeks</div>
          <div class="copy-text">{{ due_days_remaining }} days left</div>
        </div>
      </div>

      <div class="image-column">
        <div class="image-frame">
          <img class="fruit-image" src="{{ fruit_image_url }}" alt="{{ fruit_name }}">
        </div>
      </div>
    </div>
  </div>
</div>
