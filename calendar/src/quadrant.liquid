<style>
  .cal-q,
  .cal-q * {
    font-family: -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif !important;
    letter-spacing: normal !important;
  }

  .cal-q {
    min-width: 0;
  }

  .cal-q .cal-day-title {
    font-size: 21px;
    font-weight: 800;
    line-height: 1.05;
  }

  .cal-q .cal-section + .cal-section {
    margin-top: 2px;
    padding-top: 2px;
    border-top: 2px solid rgba(0, 0, 0, 0.15);
  }

  .cal-q .cal-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 2px;
    align-items: stretch;
    overflow: hidden;
  }

  .cal-q .cal-section {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: stretch;
  }

  .cal-q .cal-section-title {
    align-self: flex-start;
    text-transform: uppercase;
    letter-spacing: 1px !important;
  }

  .cal-q .cal-row {
    display: grid;
    grid-template-columns: 100px minmax(0, 1fr);
    column-gap: 8px;
    align-items: flex-start;
    min-width: 0;
  }

  .cal-q .cal-row--secondary {
    grid-template-columns: 96px minmax(0, 1fr);
  }

  .cal-q .cal-row__meta {
    min-width: 0;
  }

  .cal-q .cal-row__content {
    min-width: 0;
  }

  .cal-q .cal-time {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.1;
  }

  .cal-q .cal-time--secondary {
    font-size: 18px;
  }

  .cal-q .cal-date-muted {
    display: block;
    font-size: 17px;
    line-height: 1.1;
    opacity: 0.55;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cal-q .cal-title {
    display: block;
    min-width: 0;
    font-size: 20px;
    line-height: 1.15;
  }

  .cal-q .cal-title--secondary {
    font-size: 18px;
  }

  .cal-q .cal-location {
    display: block;
    font-size: 13px;
    line-height: 1.2;
    opacity: 0.55;
  }

  .cal-q .cal-badge {
    display: block;
    border-radius: 0 !important;
    font-weight: 600;
    margin-bottom: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
<div class="layout layout--col layout--left gap--xsmall cal-q" style="height: 100%; padding: 6px 8px; box-sizing: border-box; overflow: hidden;">
  <span class="title title--large cal-day-title">{{ today_label }}</span>

  <div class="cal-body">
    {% if has_today %}
    <div class="cal-section">
      <span class="label label--small label--gray cal-section-title">Today</span>
      {% for event in today_events %}
        {% if event.all_day %}
        <span class="label label--filled cal-badge" data-clamp="1">{{ event.title }}</span>
        {% else %}
        <div class="cal-row">
          <div class="cal-row__meta">
            <span class="value value--base cal-time">{{ event.time }}</span>
          </div>
          <div class="cal-row__content">
            <span class="description description--xlarge cal-title" data-clamp="2">{{ event.title }}</span>
            {% if event.location %}<span class="label label--small label--gray cal-location" data-clamp="1">{{ event.location }}</span>{% endif %}
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if has_tomorrow %}
    <div class="cal-section">
      <span class="label label--small label--gray cal-section-title">Tomorrow</span>
      {% for event in tomorrow_events %}
        {% if event.all_day %}
        <span class="label label--filled cal-badge" data-clamp="1">{{ event.title }}</span>
        {% else %}
        <div class="cal-row">
          <div class="cal-row__meta">
            <span class="value value--base cal-time">{{ event.time }}</span>
          </div>
          <div class="cal-row__content">
            <span class="description description--xlarge cal-title" data-clamp="2">{{ event.title }}</span>
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if has_weekend %}
    <div class="cal-section">
      <span class="label label--small label--gray cal-section-title">This Weekend</span>
      {% for event in weekend_events %}
        {% if event.all_day %}
        <span class="label label--filled cal-badge" data-clamp="1">{{ event.title }}</span>
        {% else %}
        <div class="cal-row cal-row--secondary">
          <div class="cal-row__meta">
            <span class="value value--small cal-time cal-time--secondary">{{ event.time }}</span>
          </div>
          <div class="cal-row__content">
            <span class="description description--large cal-title cal-title--secondary" data-clamp="1">{{ event.title }}</span>
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if has_later %}
    <div class="cal-section">
      <span class="label label--small label--gray cal-section-title">Later</span>
      {% for event in later_events %}
      <div class="cal-row cal-row--secondary">
        <div class="cal-row__meta">
          <span class="cal-date-muted">{{ event.date_label }}</span>
        </div>
        <div class="cal-row__content">
          <span class="description description--large cal-title cal-title--secondary" data-clamp="1">{{ event.title }}</span>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if has_upcoming %}
    <div class="cal-section">
      <span class="label label--small label--gray cal-section-title">Upcoming</span>
      {% for trip in upcoming %}
      <div class="cal-row cal-row--secondary">
        <div class="cal-row__meta">
          <span class="cal-date-muted">{{ trip.dates }}</span>
        </div>
        <div class="cal-row__content">
          <span class="description description--large cal-title cal-title--secondary" data-clamp="1">{{ trip.title }}</span>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>
