<div class="layout layout--col layout--left gap--small mbta">
  <div class="mbta-board">
    <div class="mbta-board__header">
      <span class="mbta-board__title">{{ station | upcase }}</span>
    </div>
    <div class="mbta-board__subtitle">{{ direction | upcase }}</div>
  </div>

  {% if trains.size > 0 %}
  <div class="flex flex--col gap--xsmall mbta-trains">
    {% for train in trains %}
    <div class="row row--center-y gap--space-between mbta-train-row mbta-train-row--compact{% if forloop.first %} mbta-train-row--primary{% endif %}">
      <span class="value value--small mbta-train-display">{{ train.display }}</span>
      <span class="value value--small mbta-train-time">{{ train.time }}</span>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="description description--large mbta-note">No upcoming trains</div>
  {% endif %}

  <div class="divider"></div>

  <div class="flex flex--col gap--xsmall">
    <span class="label label--small label--gray mbta-kicker">Subway Status</span>
    <div class="row row--center-y gap--small">
      <span class="label label--small label--filled mbta-pill">RL</span>
      {% if status_ok %}<span class="mbta-alert__icon">&#9679;</span>{% else %}<span class="mbta-alert__icon">&#9888;</span>{% endif %}
      <span class="description description--large mbta-status-copy" data-clamp="1">{{ subway_status }}</span>
    </div>
  </div>

  {% if live_alerts.size > 0 %}
  <div class="mbta-alert-box">
    {% for alert in live_alerts %}
    <div class="row gap--small"{% unless forloop.first %} style="margin-top: 6px;"{% endunless %}>
      <span class="mbta-alert__icon">&#9888;</span>
      <span class="description mbta-status-copy--small" data-clamp="2">{{ alert.header }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if planned_work.size > 0 %}
  <div class="flex flex--col gap--xsmall">
    <span class="label label--small label--gray mbta-kicker">Planned Work</span>
    {% for pw in planned_work %}
    <span class="description mbta-planned-copy" data-clamp="2">{{ pw.header | truncate: 120 }}</span>
    {% endfor %}
  </div>
  {% endif %}
</div>
