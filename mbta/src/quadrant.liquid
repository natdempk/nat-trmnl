<div class="layout layout--col layout--left gap--small mbta" style="height: 100%; padding: 8px 10px; box-sizing: border-box; overflow: hidden;">
  <div class="mbta-board">
    <div class="mbta-board__header">
      <span class="mbta-board__title">{{ station | upcase }}</span>
    </div>
    <div class="mbta-board__subtitle">{{ direction | upcase }}</div>
  </div>

  {% if trains.size > 0 %}
  <div class="flex flex--col gap--xsmall mbta-trains mbta-trains--center">
    {% for train in trains limit:3 %}
    <div class="row row--center-y gap--space-between mbta-train-row{% if forloop.first %} mbta-train-row--primary{% endif %}">
      <span class="value value--base mbta-train-display">{{ train.display }}</span>
      <span class="value value--base mbta-train-time">{{ train.time }}</span>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="flex flex--col mbta-trains mbta-trains--center">
    <span class="description description--xlarge mbta-note">No upcoming trains</span>
  </div>
  {% endif %}

  <div class="divider"></div>

  <div class="row row--center-y gap--small">
    <span class="label label--small label--filled mbta-pill">RL</span>
    {% if status_ok %}<span class="mbta-alert__icon">&#9679;</span>{% else %}<span class="mbta-alert__icon">&#9888;</span>{% endif %}
    <span class="description description--large mbta-status-copy" data-clamp="1">{{ subway_status }}</span>
  </div>
</div>
